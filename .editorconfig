# .editorconfig - Ensures consistent coding styles across different editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{js,jsx,ts,tsx,json,yml,yaml}]
indent_size = 2

[*.{py}]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.{sh,bash}]
indent_size = 2
